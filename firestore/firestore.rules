rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === HELPERS ===

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isProviderAdmin(providerId) {
      // Provider.id === User.id, pas besoin de get() supplémentaire
      return isAuthenticated() && request.auth.uid == providerId;
    }

    function isBookingParticipant(booking) {
      return booking.clientId == request.auth.uid ||
        isProviderAdmin(booking.providerId);
    }

    // === USERS ===

    match /users/{userId} {
      // Chaque utilisateur ne peut lire/écrire que son propre document
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // === PROVIDERS ===

    match /providers/{providerId} {
      // Lecture publique (fiches prestataires, recherche, booking flow)
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isProviderAdmin(providerId);
      allow delete: if isProviderAdmin(providerId);

      // --- MEMBERS ---
      match /members/{memberId} {
        // Lecture publique (affichage équipe + collectionGroup query par accessCode)
        allow read: if true;
        allow write: if isProviderAdmin(providerId);
      }

      // --- LOCATIONS ---
      match /locations/{locationId} {
        // Lecture publique (affichage lieux sur fiche + booking flow)
        allow read: if true;
        allow write: if isProviderAdmin(providerId);
      }

      // --- SERVICES ---
      match /services/{serviceId} {
        // Lecture publique (affichage prestations + booking flow)
        allow read: if true;
        allow write: if isProviderAdmin(providerId);
      }

      // --- SERVICE CATEGORIES ---
      match /serviceCategories/{categoryId} {
        // Lecture publique (groupement des prestations dans booking flow)
        allow read: if true;
        allow write: if isProviderAdmin(providerId);
      }

      // --- AVAILABILITY ---
      match /availability/{availabilityId} {
        // Lecture publique (calcul créneaux disponibles côté client)
        allow read: if true;
        allow write: if isProviderAdmin(providerId);
      }

      // --- BLOCKED SLOTS ---
      match /blockedSlots/{slotId} {
        // Lecture publique : nécessaire pour le calcul des créneaux disponibles
        // (schedulingService.getAvailableSlots lit les blockedSlots côté client)
        allow read: if true;
        allow write: if isProviderAdmin(providerId);
      }
    }

    // === BOOKINGS ===

    match /bookings/{bookingId} {
      // Lecture publique : nécessaire pour le calcul des créneaux disponibles
      // côté booking flow (getUpcomingByProvider query par providerId).
      // Les données sensibles (cancelToken, clientInfo) sont protégées au niveau applicatif.
      allow read: if true;

      // Création : tout le monde (réservation web publique sans compte)
      // Validation : si clientId fourni, doit correspondre à l'utilisateur authentifié
      allow create: if
        request.resource.data.clientId == null ||
        (isAuthenticated() && request.resource.data.clientId == request.auth.uid);

      // Mise à jour : participant authentifié uniquement
      allow update: if isAuthenticated() && isBookingParticipant(resource.data);

      allow delete: if false;
    }

    // === REVIEWS ===

    match /reviews/{reviewId} {
      // Lecture publique des avis publics, lecture privée pour le client/admin
      allow read: if
        resource.data.isPublic == true ||
        (isAuthenticated() && (
          resource.data.clientId == request.auth.uid ||
          isProviderAdmin(resource.data.providerId)
        ));

      // Création : client authentifié uniquement, doit être l'auteur
      allow create: if isAuthenticated() &&
        request.resource.data.clientId == request.auth.uid;

      allow update, delete: if false;
    }

    // === CONVERSATIONS ===

    match /conversations/{conversationId} {
      function isConversationParticipant() {
        return resource.data.clientId == request.auth.uid ||
          isProviderAdmin(resource.data.providerId);
      }

      allow read: if isAuthenticated() && isConversationParticipant();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isConversationParticipant();

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          isConversationParticipant();
        allow create: if isAuthenticated();
        allow update, delete: if false;
      }
    }

    // === WEBHOOK LOGS (monitoring, écrit uniquement par Admin SDK) ===

    match /_webhookLogs/{logId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // === STATS (pré-calculées par Cloud Functions, lecture serveur uniquement) ===

    match /stats/{statId} {
      allow read, write: if false;
    }

    // === ADMIN CONFIG (accessible uniquement via Admin SDK côté serveur) ===

    match /config/{configId} {
      allow read, write: if false;
    }

    // === ADMIN LOGS (accessible uniquement via Admin SDK côté serveur) ===

    match /adminLogs/{logId} {
      allow read, write: if false;
    }
  }
}
