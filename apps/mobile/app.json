{
  "expo": {
    "name": "Opatam",
    "slug": "opatam",
    "version": "1.3.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "opatam",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "primaryLanguage": "fr-FR",
    "locales": {
      "fr": "./locales/fr.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kamerleontech.opatam",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:opatam.com",
        "applinks:www.opatam.com"
      ],
      "infoPlist": {
        "CFBundleDevelopmentRegion": "fr",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Opatam utilise votre position pour vous suggérer des prestataires à proximité.",
        "LSApplicationQueriesSchemes": [
          "instagram",
          "instagram-stories",
          "fb",
          "snapchat"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "versionCode": 3,
      "package": "com.kamerleontech.opatam",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "opatam.com",
              "pathPrefix": "/p/"
            },
            {
              "scheme": "https",
              "host": "opatam.com",
              "pathPrefix": "/avis/"
            },
            {
              "scheme": "https",
              "host": "opatam.com",
              "pathPrefix": "/reservation/confirmation/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#3B82F6"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Opatam utilise votre position pour vous suggérer des prestataires à proximité."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "./plugins/withDisableExtraTranslationLint",
      "@react-native-community/datetimepicker",
      "./plugins/withFollyFix",
      [
        "react-native-share",
        {
          "android": [
            "com.instagram.android",
            "com.facebook.katana",
            "com.snapchat.android"
          ]
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.kamerleontech.opatam",
          "enableGooglePay": true
        }
      ],
      "expo-web-browser",
      [
        "react-native-fbsdk-next",
        {
          "appID": "1684425662573536",
          "clientToken": "e95d84506efebcda36c7dfdcd8820a49",
          "displayName": "Opatam",
          "scheme": "fb1684425662573536",
          "advertiserIDCollectionEnabled": true,
          "autoLogAppEventsEnabled": false,
          "isAutoInitEnabled": true,
          "iosUserTrackingPermission": "Cette autorisation permet à Opatam de mesurer l'efficacité de ses campagnes publicitaires. Refuser n'a aucun impact sur le fonctionnement de l'application."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7888b402-9fbd-40fb-a64f-146f27c140d6"
      }
    },
    "owner": "kamerleontech"
  }
}
