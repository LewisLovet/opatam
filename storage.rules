rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isImageType() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // Public brand assets (logos, social-share images, default
    // covers — anything served from the apps as static brand
    // resources). Read-only public; writes go through Firebase
    // Console / Admin SDK only.
    match /assets/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // User profile photos
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImageType() && isUnder5MB();
    }

    // Provider photos (profile, cover, portfolio)
    match /providers/{providerId}/{allPaths=**} {
      allow read: if true;
      // Write requires being the provider admin - checked via Firestore rules
      allow write: if isAuthenticated() && isImageType() && isUnder5MB();
    }

    // Vertical-landing gallery photos (one folder per vertical:
    // nail-artist, coiffeur, …). Uploaded via /admin/galleries.
    // Reads are public — the landing pages are public-facing.
    // Writes require authentication; admin authority is enforced
    // through the AdminGuard wrapper on the admin pages.
    match /landing/galleries/{slug}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isImageType() && isUnder5MB();
    }

    // In-app notification images (uploaded from /admin/notifications).
    // Public read (shown in the app); authenticated image writes,
    // admin authority enforced by the AdminGuard on the admin page.
    match /app-notifications/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isImageType() && isUnder5MB();
    }
  }
}
